%% ========================================================================
%% HEADER / FOOTER GENERATION
%% ========================================================================

% Insert the PoliNetwork logo
\newcommand{\pnInsertLogo}[1][1.2cm]{%
  \IfFileExists{\pn@logopath.pdf}{%
    \includegraphics[height=#1]{\pn@logopath.pdf}%
  }{%
    \IfFileExists{\pn@logopath.png}{%
      \includegraphics[height=#1]{\pn@logopath.png}%
    }{%
      \IfFileExists{\pn@logopath}{%
        \includegraphics[height=#1]{\pn@logopath}%
      }{%
        \textcolor{pn-text-muted}{\textit{[Logo]}}%
      }%
    }%
  }%
}

% Wordmark: "PoliNetwork" in Poppins Medium with branded colors  
\newcommand{\pnWordmark}[1][16pt]{%
  {%
    \poppinsfont\fontsize{#1}{#1}\selectfont%
    \textcolor{pn-primary}{\textbf{P}}%
    \textcolor{pn-text}{oli}%
    \textcolor{pn-primary}{\textbf{N}}%
    \textcolor{pn-text}{etwork}%
  }%
}

% Make the document header (logo + association name + contacts)
\newcommand{\pnMakeHeader}{%
  \noindent
  \begin{minipage}[c]{0.15\textwidth}
    \pnInsertLogo[1.4cm]
  \end{minipage}%
  \hfill
  \begin{minipage}[c]{0.55\textwidth}
    \pnWordmark[18pt]\\[2pt]
    {\small\color{pn-text-secondary}Associazione di Promozione Sociale}
  \end{minipage}%
  \hfill
  \begin{minipage}[c]{0.25\textwidth}
    \raggedleft
    {\footnotesize\color{pn-text-secondary}%
      \pn@email\\
      \pn@website%
    }
  \end{minipage}
  
  \vspace{2pt}
  {\color{pn-rule}\rule{\textwidth}{1.5pt}}
  \vspace{8pt}
}

% Make a compact header for subsequent pages (used by fancyhdr)
\newcommand{\pnMakeRunningHeader}{%
  \pnInsertLogo[0.8cm]%
  \hspace{6pt}%
  \pnWordmark[11pt]%
}

%% ========================================================================
%% DOCUMENT METADATA BLOCK
%% ========================================================================

\newcommand{\pnMakeMetadata}{%
  \vspace{4pt}
  \noindent
  \begin{minipage}[t]{0.48\textwidth}
    \ifthenelse{\equal{\pn@docrecipient}{}}{}{%
      {\small\color{pn-text-muted}\pn@str@to}\\
      {\normalsize\pn@docrecipient}\\[6pt]
    }
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{0.48\textwidth}
    \raggedleft\small\color{pn-text-secondary}
    \ifthenelse{\equal{\pn@docprotocol}{}}{}{%
      \pn@str@protocol: \pn@docprotocol\\
    }
    \pn@str@date: \pn@docdate%
    \ifthenelse{\equal{\pn@docversion}{}}{}{%
      \\\pn@str@version: \pn@docversion%
    }
  \end{minipage}
  \vspace{6pt}
  
  \ifthenelse{\equal{\pn@docsubject}{}}{}{%
    \noindent{\small\color{pn-text-muted}\pn@str@subject:}\\[1pt]
    \noindent{\large\color{pn-text}\textbf{\pn@docsubject}}\\[8pt]
  }
}

%% ========================================================================
%% TITLE PAGE (for reports/legal docs)
%% ========================================================================

\newcommand{\pnMakeTitlePage}{%
  \begin{titlepage}
    \centering
    \vspace*{2cm}
    
    % Logo
    \pnInsertLogo[3cm]
    
    \vspace{1cm}
    
    % Wordmark
    \pnWordmark[28pt]
    
    \vspace{0.3cm}
    {\color{pn-text-secondary}\large Associazione di Promozione Sociale}
    
    \vspace{2cm}
    
    % Decorative rule
    {\color{pn-rule}\rule{0.4\textwidth}{2pt}}
    
    \vspace{1cm}
    
    % Document title
    \ifthenelse{\equal{\pn@doctitle}{}}{}{%
      {\Huge\color{pn-text}\textbf{\pn@doctitle}}
      \vspace{0.5cm}
    }
    
    % Subtitle
    \ifthenelse{\equal{\pn@docsubtitle}{}}{}{%
      {\Large\color{pn-text-secondary}\pn@docsubtitle}
      \vspace{0.5cm}
    }
    
    \vspace{1cm}
    
    % Decorative rule
    {\color{pn-rule}\rule{0.4\textwidth}{2pt}}
    
    \vfill
    
    % Footer info
    {\small\color{pn-text-muted}%
      \ifthenelse{\equal{\pn@docversion}{}}{}{%
        \pn@str@version~\pn@docversion\quad|\quad%
      }%
      \pn@docdate%
    }
    
    \vspace{1cm}
  \end{titlepage}
}

%% ========================================================================
%% CLOSING / SIGNATURE
%% ========================================================================

\newcommand{\pnClosing}[1][Cordiali saluti,]{%
  \vspace{1.5cm}
  \noindent #1
  
  \vspace{0.8cm}
  
  \noindent
  \begin{minipage}[t]{0.5\textwidth}
    \ifthenelse{\equal{\pn@signaturepath}{}}{%
      % No signature image: leave space for manual signature
      \vspace{1.5cm}
    }{%
      \includegraphics[height=1.5cm]{\pn@signaturepath}\\[2pt]
    }%
    \rule{5cm}{0.5pt}\\[2pt]
    {\small\color{pn-text-secondary}%
      \ifthenelse{\equal{\pn@president}{}}{%
        \pn@str@president\\
        \pn@associationname%
      }{%
        \pn@president\\
        \pn@str@president\\
        \pn@associationname%
      }%
    }
  \end{minipage}
}

%% ========================================================================
%% STYLED SECTION COMMANDS
%% ========================================================================

% Primary section heading with blue accent bar
\newcommand{\pnSection}[1]{%
  \vspace{16pt}%
  \noindent%
  {\color{pn-rule}\rule{4pt}{14pt}}%
  \hspace{8pt}%
  {\Large\color{pn-text}\headlinefont\textbf{#1}}%
  \par\vspace{6pt}%
}

% Subsection
\newcommand{\pnSubsection}[1]{%
  \vspace{10pt}%
  \noindent%
  {\large\color{pn-primary}\headlinefont #1}%
  \par\vspace{4pt}%
}

%% ========================================================================
%% HIGHLIGHT BOX (for important notes)
%% ========================================================================

\newcommand{\pnHighlightBox}[1]{%
  \vspace{8pt}
  \noindent
  \begin{tikzpicture}
    \node[
      draw=pn-sky-300,
      fill=pn-sky-100,
      rounded corners=4pt,
      inner sep=10pt,
      text width=\textwidth-24pt,
      align=left
    ] {%
      \color{pn-text}#1%
    };
  \end{tikzpicture}
  \vspace{8pt}
}

% Inline highlight
\newcommand{\pnHighlight}[1]{%
  \textcolor{pn-primary}{\textbf{#1}}%
}

%% ========================================================================
%% HORIZONTAL RULE
%% ========================================================================

\newcommand{\pnRule}{%
  \vspace{6pt}
  \noindent{\color{pn-rule}\rule{\textwidth}{1pt}}
  \vspace{6pt}
}

%% ========================================================================
%% ARTICLE / CLAUSE NUMBERING (for legal documents)
%% ========================================================================

\newcounter{pn@article}
\newcounter{pn@clause}[pn@article]

\newcommand{\pnArticle}[1]{%
  \stepcounter{pn@article}%
  \vspace{14pt}%
  \noindent%
  {\color{pn-rule}\rule{4pt}{14pt}}%
  \hspace{8pt}%
  {\Large\color{pn-text}\headlinefont\textbf{Art.\,\thepn@article\quad---\quad#1}}%
  \par\vspace{6pt}%
}

\newcommand{\pnClause}[1]{%
  \stepcounter{pn@clause}%
  \vspace{6pt}%
  \noindent%
  {\color{pn-primary}\thepn@article.\thepn@clause}\hspace{6pt}%
  #1%
  \par\vspace{3pt}%
}

%% ========================================================================
%% NUMBERED SECTIONS (for privacy policies etc.)
%% ========================================================================

\newcounter{pn@numsec}

\newcommand{\pnNumberedSection}[1]{%
  \stepcounter{pn@numsec}%
  \vspace{14pt}%
  \noindent%
  {\color{pn-rule}\rule{4pt}{14pt}}%
  \hspace{8pt}%
  {\Large\color{pn-text}\headlinefont\textbf{\thepn@numsec.\quad#1}}%
  \par\vspace{6pt}%
}

%% ========================================================================
%% CONTACT INFO BLOCK (for footer or end of document)
%% ========================================================================

\newcommand{\pnContactBlock}{%
  \vspace{12pt}
  {\color{pn-rule}\rule{\textwidth}{0.5pt}}
  \vspace{6pt}
  \begin{center}
    {\small\color{pn-text-secondary}%
      \pn@associationname\quad|\quad%
      \pn@str@email: \pn@email\quad|\quad%
      PEC: \pn@pec\quad|\quad%
      \pn@str@website: \pn@website%
    }
  \end{center}
}

\endinput
