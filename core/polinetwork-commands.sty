%% ========================================================================
%% HEADER / FOOTER GENERATION
%% ========================================================================

% Insert the PoliNetwork logo
\newcommand{\pnInsertLogo}[1][1.2cm]{%
  \IfFileExists{\pn@logopath.pdf}{%
    \includegraphics[height=#1]{\pn@logopath.pdf}%
  }{%
    \IfFileExists{\pn@logopath.png}{%
      \includegraphics[height=#1]{\pn@logopath.png}%
    }{%
      \IfFileExists{\pn@logopath}{%
        \includegraphics[height=#1]{\pn@logopath}%
      }{%
        \textcolor{pn-text-muted}{\textit{[Logo]}}%
      }%
    }%
  }%
}

% Wordmark: "PoliNetwork" in Poppins Medium with pn-primary color
\newcommand{\pnWordmark}[1][16pt]{%
  {\poppinsmedium\fontsize{#1}{#1}\selectfont\color{pn-primary}PoliNetwork}%
}

% Render a rounded metadata pill.
% Parameter: #1 = short label text shown inside the pill.
\newcommand{\pnMetaPill}[1]{%
  \tikz[baseline=(pill.base)]{
    \node[
      fill=pn-white,
      draw=pn-blue-200,
      rounded corners=12pt,
      inner xsep=12pt,
      inner ysep=5pt,
      line width=0.4pt
    ] (pill) {\footnotesize\labelfont\color{pn-primary}#1};
  }%
}

% Render a compact metadata link/card with a title and description.
% Parameters: #1 = title/emphasis text, #2 = supporting description text.
\newcommand{\pnMetaLink}[2]{%
  \tikz[baseline=(link.base)]{
    \node[
      fill=white,
      fill opacity=0.82,
      text opacity=1,
      draw=pn-blue-100,
      rounded corners=7pt,
      inner xsep=12pt,
      inner ysep=6pt,
      line width=0.45pt
    ] (link) {%
      {\footnotesize\labelfont\color{pn-primary!80!pn-text}\textbf{#1}}\hspace{0.45em}%
      {\footnotesize\dmsansfont\color{pn-primary}#2}%
    };
  }%
}

% Example usage:
% \pnMetaPill{Associazione studentesca}
% \pnMetaLink{Sito web}{polinetwork.org}

% Make the document header with website-inspired spacing and typography
\newcommand{\pnMakeHeader}{%
  \vspace*{-1.5cm} % pull up slightly
  \begin{center}
    \pnInsertLogo[2cm]\\[8pt]
    \pnWordmark[34pt]\\[8pt]
    \ifthenelse{\equal{\pn@doctitle}{}}{}{%
      {\Large\color{pn-text}\headlinefont\textbf{\pn@doctitle}}\\[2pt]
    }%
    \ifthenelse{\equal{\pn@docsubtitle}{}}{}{%
      {\normalsize\color{pn-text-secondary}\poppinsfont\pn@docsubtitle}\\[6pt]
    }%
    {\small\color{pn-text-secondary}\poppinsfont
      \href{\pn@websiteurl}{\pn@website}
      \quad{\color{pn-primary}\textbf{|}}\quad
      \href{mailto:\pn@email}{\pn@email}
    }
  \end{center}
  \vspace{16pt}
}

\newcommand{\pnClosing}[1][Cordiali saluti,]{%
  \vspace{1.5cm}
  \noindent #1
  
  \vspace{0.8cm}
  
  \noindent
  \begin{minipage}[t]{0.5\textwidth}
    \ifthenelse{\equal{\pn@signaturepath}{}}{%
      % No signature image: leave space for manual signature
      \vspace{1.5cm}
    }{%
      \includegraphics[height=1.5cm]{\pn@signaturepath}\\[2pt]
    }%
    \rule{5cm}{0.5pt}\\[2pt]
    {\small\color{pn-text-secondary}%
      \ifthenelse{\equal{\pn@president}{}}{%
        \pn@str@president\\
        \pn@associationname%
      }{%
        \pn@president\\
        \pn@str@president\\
        \pn@associationname%
      }%
    }
  \end{minipage}
}

%% ========================================================================
%% STYLED SECTION COMMANDS
%% ========================================================================

% Primary section heading with blue accent bar
\newcommand{\pnSection}[1]{%
  \vspace{16pt}%
  \noindent%
  {\color{pn-rule}\rule{4pt}{14pt}}%
  \hspace{8pt}%
  {\Large\color{pn-text}\headlinefont\textbf{#1}}%
  \par\vspace{6pt}%
}

% Subsection
\newcommand{\pnSubsection}[1]{%
  \vspace{10pt}%
  \noindent%
  {\large\color{pn-primary}\headlinefont #1}%
  \par\vspace{4pt}%
}

%% ========================================================================
%% HIGHLIGHT BOX (for important notes)
%% ========================================================================

\newcommand{\pnHighlightBox}[1]{%
  \vspace{8pt}
  \noindent
  \begin{tikzpicture}
    \node[
      draw=pn-blue-100,
      fill=white,
      fill opacity=0.78,
      text opacity=1,
      rounded corners=12pt,
      line width=0.4pt,
      inner xsep=16pt,
      inner ysep=13pt,
      text width=\dimexpr\textwidth-34pt\relax,
      align=left
    ] (box) {%
      \color{pn-text}#1%
    };
    \fill[rounded corners=6pt, pn-primary]
      ($(box.north west)+(0.24,-0.26)$) rectangle ($(box.south west)+(0.08,0.26)$);
  \end{tikzpicture}
  \vspace{8pt}
}

% Inline highlight
\newcommand{\pnHighlight}[1]{%
  \textcolor{pn-primary}{\textbf{#1}}%
}

% Render a lead paragraph in the package's secondary text style.
% Parameter: #1 = introductory or summary text shown below a heading.
\newcommand{\pnLead}[1]{%
  {\large\color{pn-text-secondary}\dmsansfont #1\par}%
}

% Render an information card with a highlighted title and body copy.
% Parameters: #1 = card title, #2 = descriptive body text.
\newcommand{\pnInfoCard}[2]{%
  \begin{tikzpicture}
    \node[
      draw=pn-slate-200,
      fill=pn-white,
      rounded corners=12pt,
      line width=0.5pt,
      inner xsep=14pt,
      inner ysep=12pt,
      text width=\dimexpr\linewidth-34pt\relax,
      align=left
    ] {%
      {\large\headlinefont\color{pn-primary}\textbf{#1}}\par
      \vspace{6pt}
      {\color{pn-text}#2}
    };
  \end{tikzpicture}%
}

% Example usage:
% \pnLead{PoliNetwork promuove iniziative studentesche, tecnologiche e culturali.}
% \pnInfoCard{Contatti}{Scrivici a info@polinetwork.org per collaborazioni e supporto.}

%% ========================================================================
%% HORIZONTAL RULE
%% ========================================================================

\newcommand{\pnRule}{%
  \vspace{6pt}
  \noindent{\color{pn-rule}\rule{\textwidth}{1pt}}
  \vspace{6pt}
}

%% ========================================================================
%% ARTICLE / CLAUSE NUMBERING (for legal documents)
%% ========================================================================

\newcounter{pn@article}
\newcounter{pn@clause}[pn@article]

\newcommand{\pnArticle}[1]{%
  \stepcounter{pn@article}%
  \vspace{14pt}%
  \noindent%
  {\color{pn-rule}\rule{4pt}{14pt}}%
  \hspace{8pt}%
  {\Large\color{pn-text}\headlinefont\textbf{Art.\,\thepn@article\quad---\quad#1}}%
  \par\vspace{6pt}%
}

\newcommand{\pnClause}[1]{%
  \stepcounter{pn@clause}%
  \vspace{6pt}%
  \noindent%
  {\color{pn-primary}\thepn@article.\thepn@clause}\hspace{6pt}%
  #1%
  \par\vspace{3pt}%
}

%% ========================================================================
%% NUMBERED SECTIONS (for privacy policies etc.)
%% ========================================================================

\newcounter{pn@numsec}

\newcommand{\pnNumberedSection}[1]{%
  \stepcounter{pn@numsec}%
  \vspace{14pt}%
  \noindent%
  {\color{pn-rule}\rule{4pt}{14pt}}%
  \hspace{8pt}%
  {\Large\color{pn-text}\headlinefont\textbf{\thepn@numsec.\quad#1}}%
  \par\vspace{6pt}%
}

%% ========================================================================
%% CONTACT INFO BLOCK (for footer or end of document)
%% ========================================================================

\newcommand{\pnContactBlock}{%
  \vspace{12pt}
  {\color{pn-rule}\rule{\textwidth}{0.5pt}}
  \vspace{6pt}
  \begin{center}
    {\small\color{pn-text-secondary}%
      \pn@associationname\quad|\quad%
      \pn@str@email: \pn@email\quad|\quad%
      PEC: \pn@pec\quad|\quad%
      \pn@str@website: \pn@website%
    }
  \end{center}
}

